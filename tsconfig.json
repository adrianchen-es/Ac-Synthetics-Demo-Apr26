{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": ".synthetics",
    "rootDir": ".",
    "skipLibCheck": true
  },
  "include": ["helpers/**/*.ts", "journeys/**/*.ts", "tests/**/*.ts", "synthetics.config.ts"],
  "exclude": ["node_modules", ".synthetics"]
}
